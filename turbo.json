{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["TELEGRAM_BOT_TOKEN", "SANITY_ORG_ID", "SANITY_API_TOKEN", "SANITY_API_READ_TOKEN", "SANITY_API_WRITE_TOKEN"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
