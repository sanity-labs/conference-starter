# ──────────────────────────────────────────────────────────────
# Telegram Bot — Environment Variables
# ──────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather.
# IMPORTANT: Use a SEPARATE bot for local dev vs production.
# If both use the same bot, the production webhook and local polling
# will fight over updates — one of them will stop receiving messages.
# Create a second bot via /newbot in BotFather for local dev.
TELEGRAM_BOT_TOKEN=

# ──────────────────────────────────────────────────────────────
# Sanity — Project Configuration
# ──────────────────────────────────────────────────────────────

# Project ID (from sanity.io/manage → Project → Settings)
SANITY_PROJECT_ID=yjorde43

# Dataset name
SANITY_DATASET=production

# Organization ID (from sanity.io/manage → Organization → Settings)
# Required by the Content Agent API to locate your organization.
SANITY_ORG_ID=

# Application key — identifies which Studio workspace to use with Content Agent.
# Find it by running: contentAgent.applications() or check Sanity dashboard.
SANITY_APP_KEY=

# ──────────────────────────────────────────────────────────────
# Sanity — API Token
# ──────────────────────────────────────────────────────────────
# MUST be a **project-level** token with **Editor** role.
# Create at: sanity.io/manage → Project → API → Tokens → Add API Token
#
# Common mistake: using an Organization token instead. Org tokens
# (found under Organization → API → Tokens) will fail with error
# code SIO-401-ANF ("Session not found").
#
# This single token is used for:
#   - Content Agent API (read/write via AI)
#   - GROQ queries (allowlist, conversation history, prompts)
#   - Document mutations (conversation persistence, state)
SANITY_API_TOKEN=
