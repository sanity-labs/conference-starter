{
  "name": "everything-nyc-2026",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "typegen": "pnpm --filter @repo/studio exec sanity schema extract --enforce-required-fields && pnpm --filter @repo/studio exec sanity typegen generate",
    "predev": "tsx scripts/check-next-version.ts"
  },
  "devDependencies": {
    "@sanity/blueprints": "^0.12.2",
    "@sanity/client": "^7.15.0",
    "@sanity/functions": "^1.2.0",
    "@types/node": "^25.3.0",
    "resend": "^6.9.2",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
